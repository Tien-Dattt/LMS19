<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_corporate_lms" model="ir.module.category">
            <field name="name">Corporate LMS</field>
            <field name="description">Corporate learning management</field>
            <field name="sequence">65</field>
        </record>

        <record id="privilege_corporate_lms_access" model="res.groups.privilege">
            <field name="name">Corporate LMS Access</field>
            <field name="category_id" ref="module_category_corporate_lms"/>
            <field name="sequence">10</field>
        </record>

        <record id="group_corporate_lms_learner" model="res.groups">
            <field name="name">Corporate LMS Learner</field>
            <field name="sequence">10</field>
            <field name="privilege_id" ref="privilege_corporate_lms_access"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_corporate_lms_manager" model="res.groups">
            <field name="name">Corporate LMS Manager</field>
            <field name="sequence">20</field>
            <field name="privilege_id" ref="privilege_corporate_lms_access"/>
            <field name="implied_ids" eval="[(4, ref('group_corporate_lms_learner'))]"/>
        </record>

        <record id="group_corporate_lms_instructor" model="res.groups">
            <field name="name">Corporate LMS Instructor</field>
            <field name="sequence">30</field>
            <field name="privilege_id" ref="privilege_corporate_lms_access"/>
            <field name="implied_ids" eval="[(4, ref('group_corporate_lms_learner'))]"/>
        </record>

        <record id="group_corporate_lms_hr_officer" model="res.groups">
            <field name="name">Corporate LMS HR Officer</field>
            <field name="sequence">40</field>
            <field name="privilege_id" ref="privilege_corporate_lms_access"/>
            <field name="implied_ids" eval="[(4, ref('group_corporate_lms_learner'))]"/>
        </record>

        <record id="group_corporate_lms_training_manager" model="res.groups">
            <field name="name">Corporate LMS Training Manager</field>
            <field name="sequence">50</field>
            <field name="privilege_id" ref="privilege_corporate_lms_access"/>
            <field name="implied_ids" eval="[(4, ref('group_corporate_lms_instructor'))]"/>
        </record>

        <record id="group_corporate_lms_admin" model="res.groups">
            <field name="name">Corporate LMS Administrator</field>
            <field name="sequence">60</field>
            <field name="privilege_id" ref="privilege_corporate_lms_access"/>
            <field name="implied_ids" eval="[
                (4, ref('group_corporate_lms_training_manager')),
                (4, ref('group_corporate_lms_hr_officer')),
                (4, ref('group_corporate_lms_manager'))
            ]"/>
        </record>

    </data>
</odoo>