<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_elearning_role_track_list" model="ir.ui.view">
        <field name="name">elearning.role.track.list</field>
        <field name="model">elearning.role.track</field>
        <field name="arch" type="xml">
            <list string="Role Tracks">
                <field name="name"/>
                <field name="code"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_elearning_role_track_form" model="ir.ui.view">
        <field name="name">elearning.role.track.form</field>
        <field name="model">elearning.role.track</field>
        <field name="arch" type="xml">
            <form string="Role Track">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description" nolabel="1" placeholder="Description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_elearning_role_track_search" model="ir.ui.view">
        <field name="name">elearning.role.track.search</field>
        <field name="model">elearning.role.track</field>
        <field name="arch" type="xml">
            <search string="Role Tracks">
                <field name="name"/>
                <field name="code"/>
                <filter name="inactive" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_elearning_role_track" model="ir.actions.act_window">
        <field name="name">Role Tracks</field>
        <field name="res_model">elearning.role.track</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_elearning_role_track"
        name="Role Tracks"
        parent="menu_corporate_lms_configuration"
        action="action_elearning_role_track"
        sequence="20"
        groups="corporate_lms_base.group_corporate_lms_admin,corporate_lms_base.group_corporate_lms_training_manager"/>
</odoo>
