<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_report_program_enrollment_list" model="ir.ui.view">
        <field name="name">report.program.enrollment.list</field>
        <field name="model">elearning.program.partner</field>
        <field name="arch" type="xml">
            <list string="Program Enrollment Report">
                <field name="program_id"/>
                <field name="department_id"/>
                <field name="employee_level_id"/>
                <field name="role_track_id"/>
                <field name="partner_id"/>
                <field name="progress" widget="progressbar"/>
                <field name="final_score"/>
                <field name="state"/>
                <field name="deadline_date"/>
            </list>
        </field>
    </record>

    <record id="view_report_program_enrollment_pivot" model="ir.ui.view">
        <field name="name">report.program.enrollment.pivot</field>
        <field name="model">elearning.program.partner</field>
        <field name="arch" type="xml">
            <pivot string="Program Enrollment Report">
                <field name="program_id" type="row"/>
                <field name="department_id" type="row"/>
                <field name="state" type="col"/>
                <field name="progress" type="measure"/>
                <field name="final_score" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_report_program_enrollment_search" model="ir.ui.view">
        <field name="name">report.program.enrollment.search</field>
        <field name="model">elearning.program.partner</field>
        <field name="arch" type="xml">
            <search string="Program Enrollment Report">
                <field name="program_id"/>
                <field name="department_id"/>
                <field name="employee_level_id"/>
                <field name="role_track_id"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="deadline_date"/>
                <filter name="filter_assigned" string="Assigned" domain="[('state', '=', 'assigned')]"/>
                <filter name="filter_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_completed" string="Completed" domain="[('state', '=', 'completed')]"/>
                <filter name="filter_failed" string="Failed" domain="[('state', '=', 'failed')]"/>
                <separator/>
                <group>
                    <filter name="group_by_program" string="Program" context="{'group_by': 'program_id'}"/>
                    <filter name="group_by_department" string="Department" context="{'group_by': 'department_id'}"/>
                    <filter name="group_by_level" string="Employee Level" context="{'group_by': 'employee_level_id'}"/>
                    <filter name="group_by_role_track" string="Role Track" context="{'group_by': 'role_track_id'}"/>
                    <filter name="group_by_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_by_deadline" string="Deadline" context="{'group_by': 'deadline_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_report_program_enrollment" model="ir.actions.act_window">
        <field name="name">Program Enrollment Report</field>
        <field name="res_model">elearning.program.partner</field>
        <field name="view_mode">list,pivot,form</field>
        <field name="search_view_id" ref="view_report_program_enrollment_search"/>
    </record>

    <record id="action_report_program_enrollment_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_report_program_enrollment_list"/>
        <field name="act_window_id" ref="action_report_program_enrollment"/>
    </record>

    <record id="action_report_program_enrollment_pivot_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_report_program_enrollment_pivot"/>
        <field name="act_window_id" ref="action_report_program_enrollment"/>
    </record>

    <record id="action_report_program_enrollment_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_elearning_program_partner_form"/>
        <field name="act_window_id" ref="action_report_program_enrollment"/>
    </record>

    <menuitem
        id="menu_report_program_enrollment"
        name="Program Enrollment Report"
        parent="menu_corporate_lms_reports"
        action="action_report_program_enrollment"
        sequence="10"
        groups="corporate_lms_base.group_corporate_lms_admin,corporate_lms_base.group_corporate_lms_training_manager,corporate_lms_base.group_corporate_lms_hr_officer,corporate_lms_base.group_corporate_lms_learner"/>
</odoo>
