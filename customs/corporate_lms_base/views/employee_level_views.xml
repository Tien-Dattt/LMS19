<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_elearning_employee_level_list" model="ir.ui.view">
        <field name="name">elearning.employee.level.list</field>
        <field name="model">elearning.employee.level</field>
        <field name="arch" type="xml">
            <list string="Employee Levels" default_order="sequence, name">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_elearning_employee_level_form" model="ir.ui.view">
        <field name="name">elearning.employee.level.form</field>
        <field name="model">elearning.employee.level</field>
        <field name="arch" type="xml">
            <form string="Employee Level">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" nolabel="1" placeholder="Description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_elearning_employee_level_search" model="ir.ui.view">
        <field name="name">elearning.employee.level.search</field>
        <field name="model">elearning.employee.level</field>
        <field name="arch" type="xml">
            <search string="Employee Levels">
                <field name="name"/>
                <field name="code"/>
                <filter name="inactive" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_elearning_employee_level" model="ir.actions.act_window">
        <field name="name">Employee Levels</field>
        <field name="res_model">elearning.employee.level</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <menuitem
        id="menu_elearning_employee_level"
        name="Employee Levels"
        parent="menu_corporate_lms_configuration"
        action="action_elearning_employee_level"
        sequence="10"
        groups="corporate_lms_base.group_corporate_lms_admin,corporate_lms_base.group_corporate_lms_training_manager"/>
</odoo>
