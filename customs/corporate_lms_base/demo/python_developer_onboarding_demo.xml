            <field name="is_published">True</field>
            <field name="completion_time">0.5</field>
            <field name="description">Giới thiệu Python, phạm vi ứng dụng và quy ước học tập trong công ty.</field>
            <field name="html_content"><![CDATA[<p>Python là ngôn ngữ lập trình phổ biến cho backend, tự động hóa và phân tích dữ liệu.</p>]]></field>
        </record>
        <record id="slide_python_variables" model="slide.slide">
            <field name="name">Bài 1.2: Biến và Kiểu Dữ Liệu</field>
            <field name="channel_id" ref="corporate_lms_base.slide_channel_python_main"/>
