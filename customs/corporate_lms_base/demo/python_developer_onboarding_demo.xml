            <field name="description">Biến, kiểu số, chuỗi, danh sách và dictionary trong Python.</field>
            <field name="html_content"><![CDATA[<p>Nội dung trình bày cách khai báo biến, kiểm tra kiểu dữ liệu và chọn cấu trúc dữ liệu phù hợp.</p>]]></field>
        </record>
        <record id="slide_python_functions" model="slide.slide">
