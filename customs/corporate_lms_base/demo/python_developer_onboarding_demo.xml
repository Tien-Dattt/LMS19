            <field name="slide_category">article</field>
            <field name="is_published">True</field>
            <field name="completion_time">1.0</field>
            <field name="description">Cách định nghĩa hàm, tham số, giá trị trả về và kiểm thử đơn giản.</field>
            <field name="html_content"><![CDATA[<p>Hàm giúp đóng gói logic nghiệp vụ và làm cho mã dễ tái sử dụng trong dự án.</p>]]></field>
        </record>
        <record id="slide_python_lambda" model="slide.slide">
