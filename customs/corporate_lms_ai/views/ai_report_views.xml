<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_report_ai_source_sync_list" model="ir.ui.view">
        <field name="name">report.ai.source.sync.list</field>
        <field name="model">ai.agent.source</field>
        <field name="arch" type="xml">
            <list string="AI Source Sync Report" decoration-danger="status == 'failed'" decoration-muted="not is_active">
                <field name="type"/>
                <field name="channel_id"/>
                <field name="slide_id"/>
                <field name="status" widget="badge" decoration-success="status == 'indexed'" decoration-info="status == 'processing'" decoration-danger="status == 'failed'"/>
                <field name="user_has_access"/>
                <field name="write_date" string="Last Sync Date"/>
            </list>
        </field>
    </record>

    <record id="view_report_ai_source_sync_pivot" model="ir.ui.view">
        <field name="name">report.ai.source.sync.pivot</field>
        <field name="model">ai.agent.source</field>
        <field name="arch" type="xml">
            <pivot string="AI Source Sync Report">
                <field name="type" type="row"/>
                <field name="status" type="col"/>
                <field name="channel_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_report_ai_source_sync_search" model="ir.ui.view">
        <field name="name">report.ai.source.sync.search</field>
        <field name="model">ai.agent.source</field>
        <field name="arch" type="xml">
            <search string="AI Source Sync Report">
                <field name="type"/>
                <field name="channel_id"/>
                <field name="slide_id"/>
                <field name="status"/>
                <filter name="filter_elearning_course" string="eLearning Course" domain="[('type', '=', 'elearning_course')]"/>
                <filter name="filter_elearning_slide" string="eLearning Slide" domain="[('type', '=', 'elearning_slide')]"/>
                <separator/>
                <filter name="filter_processing" string="Processing" domain="[('status', '=', 'processing')]"/>
                <filter name="filter_indexed" string="Indexed" domain="[('status', '=', 'indexed')]"/>
                <filter name="filter_failed" string="Failed" domain="[('status', '=', 'failed')]"/>
                <group>
                    <filter name="group_by_type" string="Source Type" context="{'group_by': 'type'}"/>
                    <filter name="group_by_status" string="Sync Status" context="{'group_by': 'status'}"/>
                    <filter name="group_by_course" string="Course" context="{'group_by': 'channel_id'}"/>
                    <filter name="group_by_slide" string="Slide" context="{'group_by': 'slide_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_report_ai_source_sync" model="ir.actions.act_window">
        <field name="name">AI Source Sync Report</field>
        <field name="res_model">ai.agent.source</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[('type', 'in', ('elearning_course', 'elearning_slide'))]</field>
        <field name="search_view_id" ref="view_report_ai_source_sync_search"/>
    </record>

    <record id="action_report_ai_source_sync_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_report_ai_source_sync_list"/>
        <field name="act_window_id" ref="action_report_ai_source_sync"/>
    </record>

    <record id="action_report_ai_source_sync_pivot_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_report_ai_source_sync_pivot"/>
        <field name="act_window_id" ref="action_report_ai_source_sync"/>
    </record>

    <menuitem
        id="menu_report_ai_source_sync"
        name="AI Source Sync Report"
        parent="corporate_lms_base.menu_corporate_lms_reports"
        action="action_report_ai_source_sync"
        sequence="50"
        groups="corporate_lms_base.group_corporate_lms_admin,corporate_lms_base.group_corporate_lms_training_manager"/>
</odoo>
